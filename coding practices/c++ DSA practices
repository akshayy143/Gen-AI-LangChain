########### iterator

#include <iostream>
#include <vector>

int main() {
    std::vector<int> numbers = {10, 20, 30, 40};

    // Explicit declaration: container_type::iterator
    std::vector<int>::iterator it;

    // Loop from the beginning to the end
    for (it = numbers.begin(); it != numbers.end(); ++it) {
        std::cout << *it << " "; // Dereference to print the value
    }
    // Output: 10 20 30 40

    // Modern C++ Shortcut: Using 'auto' and range-based for loops
    // Range-based loops use iterators under the hood automatically!
    for (auto num : numbers) {
        std::cout << num << " ";
    }
}


